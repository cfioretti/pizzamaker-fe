# =============================================================================
# Pizzamaker Frontend - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust the values:
#   cp .env.example .env
#
# Create React App reads .env automatically from the project root at
# build / start time.  Only variables prefixed with REACT_APP_ are
# injected into the JS bundle.
# =============================================================================

# Base URL for all API calls (must include the versioned path prefix).
# Default points to the Traefik gateway running locally.
REACT_APP_API_BASE_URL=http://localhost:8000/api/v1
